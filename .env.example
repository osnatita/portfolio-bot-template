# Copy this file to .env.local and fill in the values.

# REQUIRED: Groq API key (free tier). Get one at https://console.groq.com/keys
GROQ_API_KEY=

# OPTIONAL: Postgres connection string, for logging conversations and capturing
# email leads. Neon has a free tier: https://neon.tech
# Leave blank to run the bot without a database (chat still works).
DATABASE_URL=

# OPTIONAL: Resend, to email you when someone leaves their address in the chat.
# https://resend.com
RESEND_API_KEY=
NOTIFICATION_EMAIL=
